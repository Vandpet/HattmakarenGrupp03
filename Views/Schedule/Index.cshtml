@model HattmakarenWebbAppGrupp03.Models.ViewModels.SchedulePageViewModel

@{
    ViewData["Title"] = Model.IsPersonal ? "Personligt schema" : "Gemensamt schema";

    var monthName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(Model.Month);
}

<h2 class="mb-4">@ViewData["Title"]</h2>

<div class="schedule-topbar mb-3">
    <a asp-action="Index"
           asp-route-personal="true"
           asp-route-year="@Model.Year"
           asp-route-month="@Model.Month"
           asp-route-day="@Model.SelectedDay"
           class="btn @(Model.IsPersonal ? "btn-dark" : "btn-outline-dark")">
        Personligt schema
    </a>

    <a asp-action="Index"
           asp-route-personal="false"
           asp-route-year="@Model.Year"
           asp-route-month="@Model.Month"
           asp-route-day="@Model.SelectedDay"
           class="btn @(!Model.IsPersonal ? "btn-dark" : "btn-outline-dark")">
        Gemensamt schema
    </a>
</div>

<div class="schedule-wrapper">
    <div class="schedule-orders">
        @if (!Model.Orders.Any())
        {
            <div class="order-card order-default">
                <div class="order-header">
                    <strong>Inga uppgifter</strong>
                </div>
                <div class="order-body">
                    <div class="task-row">
                        <span>Det finns inga uppgifter för vald dag.</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            @foreach (var order in Model.Orders)
            {
                <div class="order-card @order.ColorClass">
                    <div class="order-header">
                        <div>
                            <strong>@order.Title</strong>
                            @if (!string.IsNullOrWhiteSpace(order.CustomerName))
                            {
                                <div class="small text-muted">@order.CustomerName</div>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(order.Status))
                        {
                            <span class="badge text-bg-light">@order.Status</span>
                        }
                    </div>

                    <div class="order-body">
                        @foreach (var task in order.Tasks)
                        {
                            <div class="task-row">
                                <div class="task-left">
                                    <span class="task-title">@task.Title</span>
                                </div>

                                <div class="task-right">
                                    @if (!string.IsNullOrWhiteSpace(task.AssignedTo))
                                    {
                                        <span class="task-assigned">@task.AssignedTo</span>
                                    }
                                    <span class="task-status">@task.Status</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <div class="schedule-calendar">
        <div class="calendar-toolbar">
            <a asp-action="Index"
                   asp-route-personal="@Model.IsPersonal"
                   asp-route-year="@(Model.Month == 1 ? Model.Year - 1 : Model.Year)"
                   asp-route-month="@(Model.Month == 1 ? 12 : Model.Month - 1)"
                   asp-route-day="1"
                   class="calendar-arrow">
                &#10094;
            </a>

            <form method="get" asp-action="Index" class="calendar-form">
                <input type="hidden" name="personal" value="@Model.IsPersonal.ToString().ToLower()" />

                <select name="month" onchange="this.form.submit()" class="calendar-select">
                    @for (int m = 1; m <= 12; m++)
                    {
                        if (m == Model.Month)
                        {
                            <option value="@m" selected>
                                @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(m)
                            </option>
                        }
                        else
                        {
                            <option value="@m">
                                @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(m)
                            </option>
                        }
                    }
                </select>

                <select name="year" onchange="this.form.submit()" class="calendar-select">
                    @for (int y = DateTime.Today.Year - 2; y <= DateTime.Today.Year + 2; y++)
                    {
                        if (y == Model.Year)
                        {
                            <option value="@y" selected>@y</option>
                        }
                        else
                        {
                            <option value="@y">@y</option>
                        }
                    }
                </select>
            </form>

            <a asp-action="Index"
                   asp-route-personal="@Model.IsPersonal"
                   asp-route-year="@(Model.Month == 12 ? Model.Year + 1 : Model.Year)"
                   asp-route-month="@(Model.Month == 12 ? 1 : Model.Month + 1)"
                   asp-route-day="1"
                   class="calendar-arrow">
                &#10095;
            </a>
        </div>

        <div class="calendar-weekdays">
            <div>Sö</div>
            <div>Må</div>
            <div>Ti</div>
            <div>On</div>
            <div>To</div>
            <div>Fr</div>
            <div>Lö</div>
        </div>

        <div class="calendar-grid">
            @{
                var firstDay = new DateTime(Model.Year, Model.Month, 1);
                var startOffset = (int)firstDay.DayOfWeek;
            }

            @for (int i = 0; i < startOffset; i++)
            {
                <div class="calendar-day empty"></div>
            }

            @foreach (var day in Model.Days)
            {
                <a asp-action="Index"
                       asp-route-personal="@Model.IsPersonal"
                       asp-route-year="@Model.Year"
                       asp-route-month="@Model.Month"
                       asp-route-day="@day.Date.Day"
                       class="calendar-day @day.ColorClass @(day.IsSelected ? "selected" : "")">
                    @day.Date.Day
                </a>
            }
        </div>
    </div>
</div>