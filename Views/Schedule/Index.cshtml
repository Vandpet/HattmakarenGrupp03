@using HattmakarenWebbAppGrupp03.Models.ViewModels
@model MonthScheduleViewModel

@{
    ViewData["Title"] = "Schema";

    DateTime prevDate = Model.ViewMode == "day" ? Model.SelectedDate.AddDays(-1) :
                        (Model.ViewMode == "week" ? Model.SelectedDate.AddDays(-7) : Model.SelectedDate.AddMonths(-1));

    DateTime nextDate = Model.ViewMode == "day" ? Model.SelectedDate.AddDays(1) :
                        (Model.ViewMode == "week" ? Model.SelectedDate.AddDays(7) : Model.SelectedDate.AddMonths(1));
}

<div class="schedule-personal-toggle">
    <form method="get" asp-action="Index">
        <input type="hidden" name="targetDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="viewMode" value="@Model.ViewMode" />

        <label class="switch-label">
            <input type="checkbox"
                   name="personal"
                   value="true"
            @(Model.IsPersonal ? "checked" : null)
                   onchange="this.form.submit()" />

            <span>Visa bara min planering</span>
        </label>
    </form>
</div>

<div class="schedule-header">
    <a class="calendar-nav-btn"
           asp-action="Index"
           asp-route-targetDate="@prevDate.ToString("yyyy-MM-dd")"
           asp-route-viewMode="@Model.ViewMode"
           asp-route-personal="@Model.IsPersonal">
        ‹
    </a>

    <h2 class="schedule-title" style="margin: 0 1rem; text-align: center; min-width: 200px; text-transform: capitalize;">
        @if (Model.ViewMode == "month")
        {
            @System.Globalization.CultureInfo.GetCultureInfo("sv-SE").DateTimeFormat.GetMonthName(Model.SelectedDate.Month)
        }
        else if (Model.ViewMode == "week")
        {
            <text>Vecka @Model.WeekNumber</text>
        }
        else if (Model.ViewMode == "day")
        {
            @Model.SelectedDate.ToString("dddd d MMMM", new System.Globalization.CultureInfo("sv-SE"))
        }
    </h2>

    <a class="calendar-nav-btn"
           asp-action="Index"
           asp-route-targetDate="@nextDate.ToString("yyyy-MM-dd")"
           asp-route-viewMode="@Model.ViewMode"
           asp-route-personal="@Model.IsPersonal">
        ›
    </a>
</div>

@if (Model.IsAdmin)
{
    <div id="employeeModal" class="modal-overlay" style="display:none;">
        <div class="modal-box">
            <h3>Välj anställd</h3>

            <select id="modalEmployeeSelect" class="form-control">
                <option value="">-- Välj anställd --</option>

                @foreach (var emp in Model.Employees)
                {
                    <option value="@emp.Id">@emp.Name</option>
                }
            </select>

            <div class="modal-actions">
                <button type="button" onclick="confirmAssignment()" class="btn btn-primary">
                    Bekräfta
                </button>

                <button type="button" onclick="closeModal()" class="btn btn-secondary">
                    Avbryt
                </button>
            </div>
        </div>
    </div>
}

<div class="schedule-layout">
    <aside class="task-panel drop-unscheduled">
        <h4>Ej schemalagda</h4>

        @if (!Model.UnscheduledTasks.Any())
        {
            <div class="empty-box">Inga oschemalagda uppgifter.</div>
        }
        else
        {
            @foreach (var task in Model.UnscheduledTasks)
            {
                var taskJson = System.Text.Json.JsonSerializer.Serialize(task);

                <div class="task-card @task.ColorClass"
                     draggable="true"
                     data-order-id="@task.OrderId"
                     data-hat-id="@task.HatId"
                     data-task='@Html.Raw(taskJson)'
                     onclick="openTaskModal(this)">

                    <div class="task-card-title">@task.Title</div>
                    <div class="task-card-sub">@task.HatName</div>
                    <div class="task-card-status">@task.Status</div>

                    @if (task.ColorClass == "order-orange")
                    {
                        <div class="task-card-warning">Bör skickas snart</div>
                    }
                    else if (task.ColorClass == "order-red")
                    {
                        <div class="task-card-warning urgent">Bör skickas genast!</div>
                    }
                </div>
            }
        }
    </aside>

    <section class="calendar-panel">

        <div style="display: flex; justify-content: flex-end; margin-bottom: 1rem;">
            <div class="btn-group">
                <a asp-action="Index"
                       asp-route-targetDate="@Model.SelectedDate.ToString("yyyy-MM-dd")"
                       asp-route-viewMode="month"
                       asp-route-personal="@Model.IsPersonal"
                       class="btn @(Model.ViewMode == "month" ? "btn-lila" : "btn-rosa")"
                       style="@(Model.ViewMode == "month" ? "color: white;" : "")">
                    Månad
                </a>

                <a asp-action="Index"
                       asp-route-targetDate="@Model.SelectedDate.ToString("yyyy-MM-dd")"
                       asp-route-viewMode="week"
                       asp-route-personal="@Model.IsPersonal"
                       class="btn @(Model.ViewMode == "week" ? "btn-lila" : "btn-rosa")"
                       style="@(Model.ViewMode == "week" ? "color: white;" : "")">
                    Vecka
                </a>

                <a asp-action="Index"
                       asp-route-targetDate="@Model.SelectedDate.ToString("yyyy-MM-dd")"
                       asp-route-viewMode="day"
                       asp-route-personal="@Model.IsPersonal"
                       class="btn @(Model.ViewMode == "day" ? "btn-lila" : "btn-rosa")"
                       style="@(Model.ViewMode == "day" ? "color: white;" : "")">
                    Dag
                </a>
            </div>
        </div>

        <div class="calendar-grid view-@Model.ViewMode">
            @if (Model.ViewMode != "day")
            {
                <div class="weekday weeknumber-header">v.</div>
                <div class="weekday">Mån</div>
                <div class="weekday">Tis</div>
                <div class="weekday">Ons</div>
                <div class="weekday">Tors</div>
                <div class="weekday">Fre</div>
                <div class="weekday">Lör</div>
                <div class="weekday">Sön</div>
            }
            else
            {
                <div class="weekday" style="text-transform: capitalize;">
                    @Model.SelectedDate.ToString("dddd", new System.Globalization.CultureInfo("sv-SE"))
                </div>
            }

            @foreach (var week in Model.Weeks)
            {
                @if (Model.ViewMode != "day")
                {
                    <div class="week-number">
                        @week.WeekNumber
                    </div>
                }

                @foreach (var day in week.Days)
                {
                    <div class="calendar-cell @(day.IsCurrentMonth ? "" : "faded") @(day.IsToday ? "today" : "") drop-zone"
                         data-date="@day.Date.ToString("yyyy-MM-dd")"
                         data-events='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(day.Events))'
                         onclick="openDayModal(this)">

                        <div class="date">@day.Date.Day</div>

                        @if (Model.ViewMode == "month")
                        {
                            var ev = day.Events.FirstOrDefault(e => e.Status != "Färdig") ?? day.Events.FirstOrDefault();

                            if (ev != null)
                            {
                                var statusClass = ev.Status == "Färdig" ? "event-done" : "";

                                if (ev.EventType == "Activity")
                                {
                                    <div class="event @statusClass @ev.ColorClass">
                                        <div class="event-title">@ev.HatName</div>

                                        @if (ev.Time.HasValue)
                                        {
                                            <div class="event-sub">
                                                @ev.Time.Value.ToString(@"hh\:mm")
                                            </div>
                                        }

                                        <div class="event-sub">Aktivitet</div>
                                        <div class="event-sub"><small>@ev.EmployeeName</small></div>
                                    </div>
                                }
                                else
                                {
                                    <div class="event @statusClass @ev.ColorClass task-card"
                                         draggable="true"
                                         data-order-id="@ev.OrderId"
                                         data-hat-id="@ev.HatId">

                                        <div class="event-title">@ev.Amount x @ev.HatName</div>
                                        <div class="event-sub">Order @ev.OrderId</div>
                                        <div class="event-sub"><small>@ev.EmployeeName</small></div>
                                    </div>
                                }
                            }

                            if (day.Events.Count > 1)
                            {
                                <div class="more">+@(day.Events.Count - 1) fler</div>
                            }
                        }
                        else
                        {
                            foreach (var ev in day.Events)
                            {
                                var statusClass = ev.Status == "Färdig" ? "event-done" : "";

                                if (ev.EventType == "Activity")
                                {
                                    <div class="event @statusClass @ev.ColorClass"
                                         style="margin-bottom: 5px;">

                                        <div class="event-title">@ev.HatName</div>

                                        @if (ev.Time.HasValue)
                                        {
                                            <div class="event-sub">
                                                @ev.Time.Value.ToString(@"hh\:mm")
                                            </div>
                                        }

                                        <div class="event-sub">Aktivitet</div>
                                        <div class="event-sub"><small>@ev.EmployeeName</small></div>
                                    </div>
                                }
                                else
                                {
                                    <div class="event @statusClass @ev.ColorClass task-card"
                                         draggable="true"
                                         data-order-id="@ev.OrderId"
                                         data-hat-id="@ev.HatId"
                                         style="margin-bottom: 5px;">

                                        <div class="event-title">@ev.Amount x @ev.HatName</div>
                                        <div class="event-sub">Order @ev.OrderId</div>
                                        <div class="event-sub"><small>@ev.EmployeeName</small></div>
                                    </div>
                                }
                            }
                        }
                    </div>
                }
            }
        </div>
    </section>
</div>

<div id="dayModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <h3 id="modalDateTitle"></h3>

        <div id="modalContent"></div>

        <button onclick="closeDayModal()" class="btn btn-secondary">
            Stäng
        </button>
    </div>
</div>

<form id="dropForm" method="post" asp-action="AssignTaskToDate">
    <input type="hidden" name="orderId" id="dropOrderId" />
    <input type="hidden" name="hatId" id="dropHatId" />
    <input type="hidden" name="employeeId" id="dropEmployeeId" />
    <input type="hidden" name="date" id="dropDate" />
    <input type="hidden" name="personal" value="@Model.IsPersonal.ToString().ToLower()" />
    <input type="hidden" name="targetDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
    <input type="hidden" name="viewMode" value="@Model.ViewMode" />
</form>

<form id="unscheduleForm" method="post" asp-action="UnassignTask">
    <input type="hidden" name="orderId" id="unscheduleOrderId" />
    <input type="hidden" name="hatId" id="unscheduleHatId" />
    <input type="hidden" name="personal" value="@Model.IsPersonal.ToString().ToLower()" />
    <input type="hidden" name="targetDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
    <input type="hidden" name="viewMode" value="@Model.ViewMode" />
</form>

<form id="doneForm" method="post" asp-action="MarkDone">
    <input type="hidden" name="orderId" id="doneOrderId" />
    <input type="hidden" name="hatId" id="doneHatId" />
    <input type="hidden" name="personal" value="@Model.IsPersonal.ToString().ToLower()" />
    <input type="hidden" name="targetDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
    <input type="hidden" name="viewMode" value="@Model.ViewMode" />
</form>

<form id="deleteActivityForm" method="post" asp-action="DeleteActivity">
    <input type="hidden" name="activityId" id="deleteActivityId" />
    <input type="hidden" name="personal" value="@Model.IsPersonal.ToString().ToLower()" />
    <input type="hidden" name="targetDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
    <input type="hidden" name="viewMode" value="@Model.ViewMode" />
</form>

@section Scripts {
    <script>
        let draggedOrderId = null;
        let draggedHatId = null;
        let selectedDate = null;

        document.querySelectorAll('.task-card').forEach(card => {
            card.addEventListener('dragstart', function () {
                draggedOrderId = this.dataset.orderId;
                draggedHatId = this.dataset.hatId;
            });
        });

        document.querySelectorAll('.drop-zone').forEach(zone => {
            zone.addEventListener('dragover', e => {
                e.preventDefault();
                zone.classList.add('drag-hover');
            });

            zone.addEventListener('dragleave', () => {
                zone.classList.remove('drag-hover');
            });

            zone.addEventListener('drop', e => {
                e.preventDefault();
                zone.classList.remove('drag-hover');

                if (!draggedOrderId || !draggedHatId) return;

                selectedDate = zone.dataset.date;

                if (@Model.IsAdmin.ToString().ToLower()) {
                    openModal();
                }
                else {
                    document.getElementById("dropOrderId").value = draggedOrderId;
                    document.getElementById("dropHatId").value = draggedHatId;
                    document.getElementById("dropDate").value = selectedDate;
                    document.getElementById("dropEmployeeId").value = 0;
                    document.getElementById("dropForm").submit();
                }
            });
        });

        const unscheduledZone = document.querySelector('.drop-unscheduled');

        if (unscheduledZone) {
            unscheduledZone.addEventListener('dragover', e => {
                e.preventDefault();
                unscheduledZone.classList.add('drag-hover');
            });

            unscheduledZone.addEventListener('dragleave', () => {
                unscheduledZone.classList.remove('drag-hover');
            });

            unscheduledZone.addEventListener('drop', e => {
                e.preventDefault();
                unscheduledZone.classList.remove('drag-hover');

                if (!draggedOrderId || !draggedHatId) return;

                document.getElementById("unscheduleOrderId").value = draggedOrderId;
                document.getElementById("unscheduleHatId").value = draggedHatId;

                document.getElementById("unscheduleForm").submit();
            });
        }

        function openModal() {
            document.getElementById("employeeModal").style.display = "flex";
        }

        function closeModal() {
            document.getElementById("employeeModal").style.display = "none";
            document.getElementById("modalEmployeeSelect").value = "";
        }

        function confirmAssignment() {
            const employeeId = document.getElementById("modalEmployeeSelect").value;

            if (!employeeId) {
                alert("Välj en anställd");
                return;
            }

            document.getElementById("dropOrderId").value = draggedOrderId;
            document.getElementById("dropHatId").value = draggedHatId;
            document.getElementById("dropDate").value = selectedDate;
            document.getElementById("dropEmployeeId").value = employeeId;

            document.getElementById("dropForm").submit();
        }

        function openDayModal(element) {
            const date = element.dataset.date;
            const events = JSON.parse(element.dataset.events || "[]");

            document.getElementById("modalDateTitle").innerText = date;

            const container = document.getElementById("modalContent");
            container.innerHTML = "";

            if (events.length === 0) {
                container.innerHTML = "<p>Inga uppgifter denna dag</p>";
            }
            else {
                events.forEach(ev => {
                    const div = document.createElement("div");
                    div.classList.add("event");

                    if (ev.Status === "Färdig") {
                        div.classList.add("event-done");
                    }

                    const deliveryText = ev.PrelDeliveryDate
                        ? new Date(ev.PrelDeliveryDate).toLocaleDateString('sv-SE')
                        : "Saknas";

                    const timeText = ev.Time
                        ? ev.Time.substring(0, 5)
                        : "";

                    if (ev.EventType === "Activity") {
                        div.innerHTML = `
                            <div><strong><h5>${ev.HatName}</h5></strong></div>
                            ${timeText ? `<div>Tid: ${timeText}</div>` : ""}
                            <div>Arbetsuppgift</div>
                            <div>${ev.EmployeeName ?? ""}</div>
                            <button class="btn btn-danger btn-sm" onclick="deleteActivity(${ev.ActivityId})">
                                Ta bort
                            </button>
                            <hr style="margin:0;">
                        `;
                    }
                    else {
                        div.innerHTML = `
                            <div><strong><h5>${ev.Amount} x ${ev.HatName}</h5></strong></div>
                            <div><h6>Order ${ev.OrderId}</h6></div>
                            <div>Beräknad leverans: ${deliveryText}</div>
                            <div>${ev.EmployeeName}</div>
                            <button class="btn btn-danger btn-sm" onclick="unassignTask(${ev.OrderId}, ${ev.HatId})">Oschemalägg</button>
                            <button class="btn btn-success" onclick="markDone(${ev.OrderId}, ${ev.HatId})">Klar</button>
                            <hr style="margin:0;">
                        `;
                    }

                    container.appendChild(div);
                });
            }

            document.getElementById("dayModal").style.display = "flex";
        }

        function unassignTask(orderId, hatId) {
            document.getElementById("unscheduleOrderId").value = orderId;
            document.getElementById("unscheduleHatId").value = hatId;

            document.getElementById("unscheduleForm").submit();
        }

        function markDone(orderId, hatId) {
            document.getElementById("doneOrderId").value = orderId;
            document.getElementById("doneHatId").value = hatId;

            document.getElementById("doneForm").submit();
        }

        function deleteActivity(activityId) {
            document.getElementById("deleteActivityId").value = activityId;
            document.getElementById("deleteActivityForm").submit();
        }

        function openTaskModal(element) {
            const task = JSON.parse(element.dataset.task || "{}");

            const deliveryText = task.PrelDeliveryDate
                ? new Date(task.PrelDeliveryDate).toLocaleDateString('sv-SE')
                : "Saknas";

            document.getElementById("modalDateTitle").innerText = `Order ${task.OrderId}`;

            const container = document.getElementById("modalContent");
            container.innerHTML = `
                <div class="event">
                    <div><strong>${task.HatName ?? ""}</strong></div>
                    <div>Kund: ${task.CustomerName ?? ""}</div>
                    <div>Status: ${task.Status ?? ""}</div>
                    <div>Antal: ${task.Amount ?? ""}</div>
                    <div>Beräknad leverans: ${deliveryText}</div>
                    <div>Beskrivning: ${task.Description ?? ""}</div>
                </div>
            `;

            document.getElementById("dayModal").style.display = "flex";
        }

        function closeDayModal() {
            document.getElementById("dayModal").style.display = "none";
        }
    </script>
}