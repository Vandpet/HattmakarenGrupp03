@model HattmakarenWebbAppGrupp03.Models.ViewModels.LoginViewModel

<link rel="stylesheet" href="~/css/LoginMobile.css" asp-append-version="true" />


@{
    ViewData["Title"] = "Logga in";
}
@if (ViewBag.NoUsersExist == true)
{
    <div class="alert alert-warning">
        No users exist in the database.
        <a asp-controller="Employee" asp-action="SetupFirstUser" class="alert-link">
            Press here to create a user
        </a>
    </div>
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-header ljuslila">
                    <h3 class="mb-0">Log in</h3>
                </div>

                <div class="card-body">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label">Username</label>
                            <input asp-for="Username" class="form-control" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label">Password</label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn rosa w-100">Log in</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}