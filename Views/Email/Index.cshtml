@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Email>

<link rel="stylesheet" href="~/css/EmailIndexMobile.css" asp-append-version="true" />


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="lila-text">Inbox</h2>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="ljuslila text-white">
                    <tr>
                        <th>From</th>
                        <th>Subject</th>
                        <th>Received</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var email in Model)
                    {
                        <tr class="@(email.IsRead ? "" : "fw-bold")">
                            <td>@email.SenderEmail</td>
                            <td>@email.Subject</td>
                            <td>@email.ReceivedDate.ToString("g")</td>
                            <td>
                                @if (!email.IsRead)
                                {
                                    <span class="badge bg-primary">New</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">Read</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@email.Id" class="btn btn-sm btn-outline-secondary">Läs</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>