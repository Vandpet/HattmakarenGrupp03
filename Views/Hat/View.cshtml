@model HattmakarenWebbAppGrupp03.Models.ViewModels.HatViewViewModel

<div class="container mt-5">
	<div class="row justify-content-center">
		<div class="col-md-8 col-lg-7">
			<div class="card shadow">
				<div class="card-header ljuslila">
					<h3 class="mb-0">Hatt</h3>
				</div>

				<div class="card-body">
					<dl class="row">
						<dt class="col-sm-4">Id</dt>
						<dd class="col-sm-8">@Model.Hat.HId</dd>

						<dt class="col-sm-4">Name</dt>
						<dd class="col-sm-8">@Model.Hat.Name</dd>

						<dt class="col-sm-4">Quantity on this Order</dt>
						<dd class="col-sm-8">@Model.HatOrder.Amount</dd>

						<dt class="col-sm-4">Price</dt>
						<dd class="col-sm-8">@Model.Hat.Price.ToString("C")</dd>

						<dt class="col-sm-4">Size</dt>
						<dd class="col-sm-8">@Model.Hat.Size</dd>

						<dt class="col-sm-4">Standard Hat</dt>
						<dd class="col-sm-8">@(Model.Hat.StandardHat ? "Yes" : "No")</dd>

						<dt class="col-sm-4">Image</dt>
						<dd class="col-sm-8">
							@if (string.IsNullOrEmpty(@Model.Hat?.PicturePath))
							{
								<span class="text-muted">Unavailable</span>
							}
							else
							{
								   <img src="@Model.Hat?.PicturePath" alt="@Model.Hat?.Name" class="img-fluid" style="max-height:200px;" />
							}
						</dd>

						<dt class="col-sm-4">KN-Number</dt>
						<dd class="col-sm-8">@Model.Hat.KN_Number</dd>

						<dt class="col-sm-4">KN-Description</dt>
						<dd class="col-sm-8">@Model.Hat.KN_Description</dd>

						<dt class="col-sm-4">Description</dt>
						<dd class="col-sm-8">@Model.Hat.Description</dd>

						
					</dl>

					<div class="d-flex gap-2">
						<a asp-controller="Order" asp-action="Details" asp-route-oId="@Model.PreviousOrder.OId" class="btn rosa fw-bold" style="margin: 0 0.5rem 1rem 0;">Back</a>
						@if (Model.HatOrder.Status == "Shipped" && 
						(Model.PreviousOrder.Status == "Shipped" || Model.PreviousOrder.Status == "Partially Returned"))
						{
							<form asp-controller="Hat" asp-action="ReturnOrder" asp-route-oId="@Model.PreviousOrder.OId" asp-route-hId="@Model.HatOrder.HId" method="post">
								<button type="submit" class="btn rosa fw-bold">Return Product</button>
							</form>
						}
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<div class="modal fade" id="imageModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">

			<div class="modal-header">
				<h5 class="modal-title">Image</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>

			<div class="modal-body text-center">
				<img id="modalImage" class="img-fluid" />
			</div>

		</div>
	</div>
</div>

<script>
	var imageModal = document.getElementById('imageModal');

	imageModal.addEventListener('show.bs.modal', function (event) {
		var button = event.relatedTarget;
		var imgSrc = button.getAttribute('data-img');
		document.getElementById('modalImage').src = imgSrc;
	});
</script>