@model HattmakarenWebbAppGrupp03.Models.HatCreateViewModel

@{
    ViewData["Title"] = "Create Hat";
}

<h2>Skapa ny hatt</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Size"></label>
        <input asp-for="Size" class="form-control" />
        <span asp-validation-for="Size" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PicturePath"></label>
        <input asp-for="PicturePath" class="form-control" />
        <span asp-validation-for="PicturePath" class="text-danger"></span>
    </div>

    <!-- Materialer (enkel version, kan förbättras med dropdown/checkboxlista) -->
   @*  <div class="form-group">
        <label>Material (ange som text eller hantera separat)</label>
        <input type="text" name="Materials" class="form-control" />
    </div> *@

    <button type="submit" class="btn btn-primary">Spara</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}