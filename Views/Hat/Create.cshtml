@model HattmakarenWebbAppGrupp03.Models.ViewModels.HatCreateViewModel

@{
    ViewData["Title"] = "Skapa Hatt";
}

<h2>Skapa ny hatt</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <!-- VALIDATION SUMMARY -->
    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- HATT-SEKTION -->
    <div class="card p-3 mb-4">

        <div class="form-group form-check mb-3">
            <input asp-for="StandardHat" class="form-check-input" type="checkbox" />
            <label asp-for="StandardHat" class="form-check-label">
                Standardmodell
            </label>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Price"></label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Size"></label>
            <input asp-for="Size" class="form-control" />
            <span asp-validation-for="Size" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="ImageFile">Bild</label>
            <input asp-for="ImageFile" type="file" class="form-control" />
            <span asp-validation-for="ImageFile" class="text-danger"></span>
        </div>
    </div>

    <!-- MATERIAL-SEKTION -->
    <div class="card p-3 mb-4">
        <h4>Material</h4>

        <div id="materials-container">

            <!-- första raden -->
            <div class="material-item border p-2 mb-3">
                <input name="Materials[0].Name" class="form-control mb-1" placeholder="Namn" />
                <input name="Materials[0].Amount" class="form-control mb-1" placeholder="Mängd" type="number" step="0.01" />
                <input name="Materials[0].MeasuringUnits" class="form-control mb-1" placeholder="Enhet" />
                <input name="Materials[0].Price" class="form-control mb-1" placeholder="Pris" type="number" step="0.01" />
            </div>

        </div>

        <button type="button" class="btn btn-success" onclick="addMaterial()">
            + Lägg till material
        </button>
    </div>

    <!-- KNAPPAR -->
    <div class="form-group">
        <button type="submit" class="btn btn-primary">Spara hatt</button>
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Avbryt</a>
    </div>

</form>

<!-- TEMPLATE (viktig fix för stabil binding) -->
<div id="material-template" style="display:none;">
    <div class="material-item border p-2 mb-3">
        <input class="form-control mb-1 name" placeholder="Namn" />
        <input class="form-control mb-1 amount" placeholder="Mängd" type="number" step="0.01" />
        <input class="form-control mb-1 unit" placeholder="Enhet" />
        <input class="form-control mb-1 price" placeholder="Pris" type="number" step="0.01" />
        
        <button type="button" class="btn btn-danger btn-sm mt-2 remove-btn">
            Ta bort
        </button>
    </div>
</div>

@section Scripts {
    <script>
        function addMaterial() {
            const container = document.getElementById("materials-container");

            const index = container.querySelectorAll(".material-item").length;

            const template = document.querySelector("#material-template .material-item");
            const clone = template.cloneNode(true);

            clone.querySelector(".name")
                .setAttribute("name", `Materials[${index}].Name`);

            clone.querySelector(".amount")
                .setAttribute("name", `Materials[${index}].Amount`);

            clone.querySelector(".unit")
                .setAttribute("name", `Materials[${index}].MeasuringUnits`);

            clone.querySelector(".price")
                .setAttribute("name", `Materials[${index}].Price`);

            container.appendChild(clone);
        }

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-btn")) {
                e.target.closest(".material-item").remove();
                reindexMaterials();
            }
        });

        function reindexMaterials() {
            const items = document.querySelectorAll(".material-item");

            items.forEach((item, index) => {
                item.querySelectorAll("input").forEach(input => {
                    if (input.name.includes("Name"))
                        input.name = `Materials[${index}].Name`;

                    else if (input.name.includes("Amount"))
                        input.name = `Materials[${index}].Amount`;

                    else if (input.name.includes("MeasuringUnits"))
                        input.name = `Materials[${index}].MeasuringUnits`;

                    else if (input.name.includes("Price"))
                        input.name = `Materials[${index}].Price`;
                });
            });
        }
    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
}