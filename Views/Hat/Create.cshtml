@model HattmakarenWebbAppGrupp03.Models.ViewModels.HatCreateViewModel

@{
    ViewData["Title"] = "Skapa Hatt";
}

<h2>Skapa ny hatt</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Hattens namn</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label">Pris</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Size" class="control-label">Storlek</label>
                <input asp-for="Size" class="form-control" />
            </div>

            @* MATERIAL-SEKTIONEN *@
            <div class="form-group mb-3">
                <label class="control-label">Välj material</label>
                <div class="card p-3" style="max-height: 200px; overflow-y: auto; background-color: #f8f9fa;">
                    @for (int i = 0; i < Model.AvailableMaterials.Count; i++)
                    {
                        <div class="form-check">
                            <input type="checkbox"
                                   name="SelectedMaterialIds"
                                   value="@Model.AvailableMaterials[i].Id"
                                   class="form-check-input" />
                            <label class="form-check-label">@Model.AvailableMaterials[i].Name</label>
                        </div>
                    }
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Spara hatt</button>
                <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Avbryt</a>
            </div>
        </form>
    </div>
</div>