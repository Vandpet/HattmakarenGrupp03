@model HattmakarenWebbAppGrupp03.Models.ViewModels.HatCreateViewModel

<link rel="stylesheet" href="~/css/CreateHatMobile.css" asp-append-version="true" />


@{
    bool isEdit = ViewBag.IsEdit == true;
    ViewData["Title"] = isEdit ? "Edit Hat" : "Create Hat";
}

<h2>@(isEdit ? "Edit Hat" : "Create New Hat")</h2>

<form asp-action="@(isEdit ? "Edit" : "Create")"
      asp-route-id="@(isEdit ? Model.HId : null)"
      method="post"
      enctype="multipart/form-data">

    <!-- HATT-SEKTION -->
    <div class="card p-3 mb-4">

        @if (isEdit)
        {
        <input asp-for="HId" type="hidden" />
        }

        @* CHECKBOX *@
        <div class="d-flex align-items-center gap-2 px-3 py-1 bg-rosa form-switch mb-3 border-5" style="width: fit-content; border-radius: 1rem;">
            <input asp-for="StandardHat" class="form-check-input m-0" type="checkbox" id="standardHatToggle"/>
            <label asp-for="StandardHat" class="mb-0">Standard model</label>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Name">Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Price">Price</label>
            <input asp-for="Price" class="form-control" type="text" inputmode="decimal" data-val="false" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        @* STORLEK *@
        <div class="form-group mb-3">
            <label asp-for="Size">Size
                <i class="bi bi-info-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="right"
                   title="Standard sizes represent the hat’s inner lining length (XS–XL). Custom hats use free text, preferably describing dimensions such as inner circumference, outer width, and height.">
                </i>
            </label>

            @* TEXTINPUT *@
            <input asp-for="Size" id="size-text" class="form-control" />

            @* DROPBOX *@
            <select asp-for="Size" id="size-select" class="form-control d-none">
                <option value="">-- Choose Size --</option>
                @foreach (var item in Model.SizeOptions)
                {
                    <option value="@item">@item</option>
                }
            </select>

            <div class="d-flex flex-column"> @* Div här så att de inte ligger inline med varannn *@
                <small id="size-help" class="text-muted">Standard models have set sizes.</small>
                <span asp-validation-for="Size" class="text-danger"></span>
            </div>

        </div>

        <div class="form-group mb-3">
            <label asp-for="ImageFile" class="form-label">Image</label>

            @if (!string.IsNullOrWhiteSpace(Model.PicturePath))
            {
                <div class="card p-3">

                    <div class="mb-3 text-center">
                        <img src="@Model.PicturePath"
                             alt="Current image"
                             class="img-fluid border rounded"
                             style="max-height:220px;" />
                    </div>

                    <div class="border rounded p-3 bg-light">
                        <div class="fw-semibold mb-2">Replace image</div>

                        <input asp-for="ImageFile" type="file" class="form-control mb-2" />

                        <small class="text-muted">
                            Choose a new file to replace current image.
                        </small>
                    </div>

                </div>
            }
            else
            {
                <input asp-for="ImageFile" type="file" class="form-control" />

                <small class="text-muted">
                    You can upload an image if you want.
                </small>
            }

            <span asp-validation-for="ImageFile" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label for="SelectedKN">Choose KN-Nummer</label>

            <select asp-for="SelectedKN" class="form-control">
                <option value="">-- Choose KN-number --</option>
                @foreach (var item in Model.KN_options)
                {
                    <option value="@item">@item</option>
                }
            </select>
            <span asp-validation-for="SelectedKN" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>


    </div>

    <!-- MATERIAL-SEKTION -->
    <div class="card p-3 mb-4">
        <h4>Material</h4>

        <div id="materials-container">

            @if (Model != null && Model.Materials != null && Model.Materials.Any(m => m != null))
            {
                for (int i = 0; i < Model.Materials.Count; i++)
                {
                    var material = Model.Materials[i] ?? new MaterialCreateViewModel();

                    <div class="material-item border p-2 mb-3">
                        <label asp-for="Materials" class="form-label">Name</label>
                        <input name="Materials[@i].Name" class="form-control mb-1" value="@material.Name" />
                        <label asp-for="Materials" class="form-label">Amount</label>
                        <input name="Materials[@i].Amount" class="form-control mb-1" type="text" inputmode="decimal" value="@material.Amount" />

                        <label asp-for="Materials" class="form-label">Unit</label>
                        @* SELECT för enhet (endast EN kontroll) *@
                        <select name="Materials[@i].MeasuringUnits" class="form-control mb-1 unit">
                            <option value="">-- Choose unit --</option>
                            @foreach (var u in Model.MeasuringUnits)
                            {
                                if (u == material.MeasuringUnits)
                                {
                                    <option value="@u" selected="selected">@u</option>
                                }
                                else
                                {
                                    <option value="@u">@u</option>
                                }
                            }
                        </select>
                        <label asp-for="Materials" class="form-label">Price</label>
                        <input name="Materials[@i].Price" class="form-control mb-1" type="text" inputmode="decimal" value="@material.Price" />

                        <button type="button" class="btn btn-danger btn-sm mt-2 remove-btn">
                            Remove
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="material-item border p-2 mb-3">
                    <label class="form-label">Name</label>
                    <input name="Materials[0].Name" class="form-control mb-1" />
                    <label class="form-label">Amount</label>
                    <input name="Materials[0].Amount" class="form-control mb-1" type="number" step="0.01" />

                    <label class="form-label">Unit</label>
                    <select name="Materials[0].MeasuringUnits" class="form-control mb-1 unit">
                        <option value="">-- Choose unit --</option>
                        @foreach (var u in Model.MeasuringUnits)
                        {
                            <option value="@u">@u</option>
                        }
                    </select>

                    <label class="form-label">Price</label>
                    <input name="Materials[0].Price" class="form-control mb-1" type="number" step="0.01" />

                    <button type="button" class="btn btn-danger btn-sm mt-2 remove-btn">
                        Remove
                    </button>
                </div>
            }

        </div>

        <button type="button" class="btn btn-success" onclick="addMaterial()">
            + Add Material
        </button>
    </div>

    <!-- BUTTONS -->
    <div class="form-group">
        <button type="submit" class="btn rosa fw-bold">Save Hat</button>
        <a asp-action="Index" asp-controller="Hat" class="btn rosa fw-bold">Cancel</a>
    </div>

</form>

<!-- TEMPLATE (important fix for stable binding) -->
<div id="material-template" style="display:none;">
    <div class="material-item border p-2 mb-3">
        <label asp-for="Materials" class="form-label">Name</label>
        <input class="form-control mb-1 name" />
        <label asp-for="Materials" class="form-label">Amount</label>
        <input class="form-control mb-1 amount" type="number" step="0.01" />

        <label asp-for="Materials" class="form-label">Unit</label>
        <select class="form-control mb-1 unit">
            <option value="">-- Choose unit --</option>
            @foreach (var u in Model.MeasuringUnits)
            {
                <option value="@u">@u</option>
            }
        </select>

        <label asp-for="Materials" class="form-label">Price</label>
        <input class="form-control mb-1 price" type="number" step="0.01" />
        
        <button type="button" class="btn btn-danger btn-sm mt-2 remove-btn">
            Remove
        </button>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        function addMaterial() {
            const container = document.getElementById("materials-container");

            const index = container.querySelectorAll(".material-item").length;

            const template = document.querySelector("#material-template .material-item");
            const clone = template.cloneNode(true);

            clone.querySelector(".name")
                .setAttribute("name", `Materials[${index}].Name`);

            clone.querySelector(".amount")
                .setAttribute("name", `Materials[${index}].Amount`);

            clone.querySelector(".unit")
                .setAttribute("name", `Materials[${index}].MeasuringUnits`);

            clone.querySelector(".price")
                .setAttribute("name", `Materials[${index}].Price`);

            container.appendChild(clone);
        }

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-btn")) {
                e.target.closest(".material-item").remove();
                reindexMaterials();
            }
        });

        function reindexMaterials() {
            const items = document.querySelectorAll(".material-item");

            items.forEach((item, index) => {
                // include both inputs and selects
                item.querySelectorAll("input, select").forEach(el => {
                    if (!el.name) return;

                    if (el.name.includes("Name"))
                        el.name = `Materials[${index}].Name`;

                    else if (el.name.includes("Amount"))
                        el.name = `Materials[${index}].Amount`;

                    else if (el.name.includes("MeasuringUnits"))
                        el.name = `Materials[${index}].MeasuringUnits`;

                    else if (el.name.includes("Price"))
                        el.name = `Materials[${index}].Price`;
                });
            });
        }

        document.addEventListener("DOMContentLoaded", function () {

            //Sätter igång tooltip:en bredvid Size.
            document.querySelectorAll('[data-bs-toggle="tooltip"]')
            .forEach(el => new bootstrap.Tooltip(el));

            const checkbox = document.getElementById("standardHatToggle");
            const textInput = document.getElementById("size-text");
            const selectInput = document.getElementById("size-select");
			const sizeHelp = document.getElementById("size-help");

            function updateSizeField() {
                if (checkbox.checked) {
                    selectInput.classList.remove("d-none");
                    textInput.classList.add("d-none");
                    sizeHelp.classList.remove("d-none");

					textInput.disabled = true;
		            selectInput.disabled = false;
                }
                else {
                    textInput.classList.remove("d-none");
                    selectInput.classList.add("d-none");
                    sizeHelp.classList.add("d-none");

                    textInput.disabled = false;
                    selectInput.disabled = true;
                }
            }

            // Körs när man kommer in på sidan eftersom checkboxen är förifylld.
            updateSizeField();

            // Checkboxen kör metoden vid ändring
            checkbox.addEventListener("change", updateSizeField);
        });
    </script>
}