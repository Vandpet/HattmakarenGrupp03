@model HattmakarenWebbAppGrupp03.Models.Hat

@{
    ViewData["Title"] = "Redigera hatt";
    int? currentEmployeeId = Context.Session.GetInt32("EmployeeId");
}

<div class="container mt-4">
    <h2>Edit hat</h2>

    <form asp-action="Edit" asp-controller="Hat" asp-route-id="@Model.HId" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="HId" type="hidden" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Price" class="form-label">Price</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Size" class="form-label">Size</label>
                <input asp-for="Size" class="form-control" />
                <span asp-validation-for="Size" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3 form-check">
                <input asp-for="StandardHat" class="form-check-input" />
                <label asp-for="StandardHat" class="form-check-label">Standard hat</label>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Image (upload new to replace old image)</label>
            @if (!string.IsNullOrWhiteSpace(Model.PicturePath))
            {
                <div class="mb-2">
                    <img src="@Model.PicturePath" alt="@Model.Name" style="max-height:160px;" />
                </div>
            }
            <input type="file" name="ImageFile" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Material (viewable, not editable)</label>
            @if (Model.Materials != null && Model.Materials.Any())
            {
                <ul class="list-group">
                    @foreach (var hm in Model.Materials)
                    {
                        <li class="list-group-item">
                            @hm.Material?.Name
                            @if (hm.Material != null)
                            {
                                <span class="text-muted"> — @hm.Material.Amount @hm.Material.MeasuringUnits</span>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-muted">No material</div>
            }
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" asp-controller="Hat" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}