@model HattmakarenWebbAppGrupp03.Models.Hat

@{
    ViewData["Title"] = "Visa hatt";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header ljuslila">
                    <h3 class="mb-0">@Model.Name</h3>
                </div>

                <div class="card-body">
                    <dl class="row">

                        <dt class="col-sm-4">Price</dt>
                        <dd class="col-sm-8">@Model.Price.ToString("C")</dd>

                        <dt class="col-sm-4">Size</dt>
                        <dd class="col-sm-8">@Model.Size</dd>

                        <dt class="col-sm-4">Image</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.PicturePath))
                            {
                                <img src="@Model.PicturePath" alt="@Model.Name" class="img-fluid" style="max-height:200px;" />
                            }
                            else
                            {
                                <span class="text-muted">No image</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Standard</dt>
                        <dd class="col-sm-8">@(Model.StandardHat ? "Yes" : "No")</dd>

                        <dt class="col-sm-4">KN-Number</dt>
                        <dd class="col-sm-8">@Model.KN_Number</dd>

                        <dt class="col-sm-4">KN-Description</dt>
                        <dd class="col-sm-8">@Model.KN_Description</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>

                        <dt class="col-sm-4">Material</dt>
                        <dd class="col-sm-8">
                            @if (Model.Materials != null && Model.Materials.Any())
                            {
                                <ul class="mb-0">
                                    @foreach (var hm in Model.Materials)
                                    {
                                        <li>
                                            @hm.Material?.Name
                                            @if (hm.Material != null)
                                            {
                                                <span class="text-muted"> — @hm.Material.Amount @hm.Material.MeasuringUnits</span>
                                            }
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">No material</span>
                            }
                        </dd>

                    </dl>
                    <div class="mt-3">
                        <a asp-action="Index" class="btn rosa fw-bold">Back</a>
                        <a asp-action="Edit" asp-route-id="@Model.HId" class="btn rosa fw-bold">Edit</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>