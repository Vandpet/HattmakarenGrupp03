@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Hat>

@{
    ViewData["Title"] = "Hattar";
    int? currentEmployeeId = Context.Session.GetInt32("EmployeeId");
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Hattar</h2>
        <div class="d-flex gap-2">
            <a asp-controller="Hat" asp-action="Create" class="btn btn-success">Ny hatt</a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="bg-primary text-white">
                    <tr>
                        <th>ID</th>
                        <th>Namn</th>
                        <th>Pris</th>
                        <th>Storlek</th>
                        <th>Bild</th>
                        <th>Standard</th>
                        <th>Beskrivning</th>
                        <th style="width: 180px;">Åtgärder</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hat in Model)
                    {
                        <tr>
                            <td>@hat.HId</td>
                            <td>@hat.Name</td>
                            <td>@hat.Price.ToString("C")</td>
                            <td>@hat.Size</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(hat.PicturePath))
                                {
                                    <img src="@hat.PicturePath" alt="@hat.Name" style="height:40px;" />
                                }
                            </td>
                            <td>@(hat.StandardHat ? "Ja" : "Nej")</td>
                            <td>@hat.Description</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="View" asp-route-id="@hat.HId" class="btn btn-sm btn-primary">Visa</a>
                                    <a asp-action="Edit" asp-route-id="@hat.HId" class="btn btn-sm btn-primary">Redigera</a>
                                    <a asp-action="Delete" asp-route-id="@hat.HId" class="btn btn-sm btn-danger">Ta bort</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>