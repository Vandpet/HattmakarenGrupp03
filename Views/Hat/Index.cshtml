@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Hat>

<link rel="stylesheet" href="~/css/IndexHatMobile.css" asp-append-version="true" />


@{
	ViewData["Title"] = "Hats";
	int? currentEmployeeId = Context.Session.GetInt32("EmployeeId");
}

<div class="container mt-5">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="mb-0">Hats</h2>
		<div class="d-flex gap-2">
			<a asp-controller="Hat" asp-action="Create" class="btn btn-rosa">New Hat</a>
		</div>
	</div>

	<div class="card shadow">
		<div class="card-header ljuslila text-white">
			<div class="row g-2 align-items-center">
				<div class="col-md-6">
					<input type="text" id="hatSearch" class="form-control" placeholder="Search hats..." />
				</div>

				<div class="col-md-6 d-flex justify-content-md-end align-items-center">
					<div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
						<input class="form-check-input mt-0"
							   type="checkbox"
							   id="showSpecialHats"
							   style="cursor:pointer; border-color:white;" />
						<label class="form-check-label text-white mb-0" for="showSpecialHats" style="cursor:pointer;">
							Show special hats
						</label>
					</div>
				</div>
			</div>
		</div>

		<div class="card-body">
			<table class="table table-hover align-middle mb-0" id="hatTable">
				<thead class="lila text-white">
					<tr>
						<th>ID</th>
						<th>Name</th>
						<th>Price</th>
						<th>Size</th>
						<th>Image</th>
						<th>Standard</th>
						<th>Description</th>
						<th style="width: 180px;">Actions</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var hat in Model)
					{
						<tr data-standard="@hat.StandardHat.ToString().ToLower()">
							<td>@hat.HId</td>
							<td>@hat.Name</td>
							<td>@hat.Price.ToString("C")</td>
							<td>@hat.Size</td>
							<td>
								@if (!string.IsNullOrWhiteSpace(hat.PicturePath))
								{
									<img src="@hat.PicturePath" alt="@hat.Name" class="img-thumbnail" style="height:48px; width:auto;" />
								}
							</td>
							<td>
								@if (hat.StandardHat)
								{
									<span class="badge bg-rosa text-purple">Standard</span>
								}
								else
								{
									<span class="badge bg-light text-muted">Special</span>
								}
							</td>
							<td>
								@{
									var desc = hat.Description ?? "";
									var shortDesc = desc.Length > 60
									? desc.Substring(0, 60) + "..."
									: desc;
								}
								@shortDesc
							</td>
							<td>
								<div class="d-flex gap-2">
									<a asp-action="Details" asp-route-id="@hat.HId" class="btn btn-sm btn-ljuslila">View</a>
									<a asp-action="Edit" asp-route-id="@hat.HId" class="btn btn-sm btn-ljuslila">Edit</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>


		</div>
	</div>

	<div class="grid-container" id="hatGrid">
		@foreach (var hat in Model)
		{
			<div class="d-flex flex-column align-items-center p-2 card shadow grid-item">

				@* BILD *@
				<div class="card p-2">
					@if (!string.IsNullOrWhiteSpace(hat.PicturePath))
					{
						<img src="@hat.PicturePath" alt="@hat.Name" class="hat-img shadow" />
					}
					else
					{
						<img src="/uploads/36bf70c5-8064-45e2-a730-d779ff0bf64f.jpg" alt="Image unavailable" class="hat-img shadow" />
					}
				</div>

				@* NAME *@
				<div class="mt-2">
					<h4>@hat.Name</h4>
				</div>

				@* INFO *@
				<div class="d-flex flex-row w-100 justify-content-around my-2">
					<div class="d-flex flex-column">
						<span><strong>Id:</strong> @hat.HId</span>
						@* <span><strong>Name:</strong> @hat.Name</span> *@
						<span><strong>Size:</strong> @hat.Size</span>
					</div>

					<div class="d-flex flex-column">
						<span><strong>Price:</strong> @hat.Price.ToString("C")</span>
						<span class="badge bg-ljuslila text-black">
							@(hat.StandardHat ? "Standard hat" : "Special hat")
						</span>
					</div>
				</div>

				@* BESKRIVNING *@
				<div class="d-flex justify-content-center card mb-2" style="width: 90%">
					<p class="m-1 truncate-3 text-muted">
						@hat.Description
					</p>
				</div>

				@* KNAPPAR *@
				<div class="w-100 d-flex justify-content-around mt-auto">
					<a asp-action="Details" asp-route-id="@hat.HId" class="btn btn-sm btn-rosa py-1 px-3" style="width: 45%;">View</a>

					@* <span class="badge bg-ljuslila text-black align-self-center">
						@(hat.StandardHat ? "Standard" : "Special")
					</span> *@

					<a asp-action="Edit" asp-route-id="@hat.HId" class="btn btn-sm btn-rosa py-1 px-3" style="width: 45%;">Edit</a>
				</div>

			</div>
		}
	</div>
</div>

@section Scripts {
	<script>
		function normalizeText(text) {
			return (text || "")
				.toLowerCase()
				.replace(/\s/g, "")     // remove all whitespace
				.replace(/,/g, ".");    // convert comma to dot
		}

		function filterHats() {
			const searchValue = normalizeText(document.getElementById("hatSearch").value);
			const showSpecial = document.getElementById("showSpecialHats").checked;
			const rows = document.querySelectorAll("#hatTable tbody tr");

			rows.forEach(row => {
				const isStandard = row.dataset.standard === "true";
				const rowText = normalizeText(row.innerText);

				const matchesSearch = rowText.includes(searchValue);
				const matchesStandardFilter = showSpecial ? true : isStandard;

				row.style.display = (matchesSearch && matchesStandardFilter) ? "" : "none";
			});
		}

		document.getElementById("hatSearch").addEventListener("input", filterHats);
		document.getElementById("showSpecialHats").addEventListener("change", filterHats);

		document.addEventListener("DOMContentLoaded", function () {
			filterHats();
		});
	</script>
}