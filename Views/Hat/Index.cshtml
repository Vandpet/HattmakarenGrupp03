@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Hat>

<link rel="stylesheet" href="~/css/IndexHatMobile.css" asp-append-version="true" />


@{
    ViewData["Title"] = "Hats";
    int? currentEmployeeId = Context.Session.GetInt32("EmployeeId");
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Hattar</h2>
        <div class="d-flex gap-2">
            <a asp-controller="Hat" asp-action="Create" class="btn btn-success">New hats</a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <div class="row g-2 align-items-center">
                <div class="col-md-6">
                    <input type="text" id="hatSearch" class="form-control" placeholder="Search for hat..." />
                </div>
                <div class="d-flex justify-content-md-end align-items-center h-100">
                    <div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
                        <input class="form-check-input mt-0"
                               type="checkbox"
                               id="showSpecialHats"
                               style="cursor:pointer; border-color:white;" />
                        <label class="form-check-label text-white mb-0" for="showSpecialHats" style="cursor:pointer;">
                            Show special hats
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body">
            <table class="table table-striped table-hover align-middle mb-0" id="hatTable">
                <thead class="bg-primary text-white">
                    <tr>
                        <th>ID</th>
                        <th>Namn</th>
                        <th>Pris</th>
                        <th>Storlek</th>
                        <th>Bild</th>
                        <th>Standard</th>
                        <th>Beskrivning</th>
                        <th style="width: 180px;">Åtgärder</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hat in Model)
                    {
                        <tr data-standard="@hat.StandardHat.ToString().ToLower()">
                            <td>@hat.HId</td>
                            <td>@hat.Name</td>
                            <td>@hat.Price.ToString("C")</td>
                            <td>@hat.Size</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(hat.PicturePath))
                                {
                                    <img src="@hat.PicturePath" alt="@hat.Name" style="height:40px;" />
                                }
                            </td>
                            <td>@(hat.StandardHat ? "Ja" : "Nej")</td>
                            <td>
                                @{
                                    var desc = hat.Description ?? "";
                                    var shortDesc = desc.Length > 60
                                    ? desc.Substring(0, 60) + "..."
                                    : desc;
                                }
                                @shortDesc
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@hat.HId" class="btn btn-sm btn-primary">Visa</a>
                                    <a asp-action="Edit" asp-route-id="@hat.HId" class="btn btn-sm btn-primary">Redigera</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function normalizeText(text) {
            return (text || "")
                .toLowerCase()
                .replace(/\s/g, "")     // tar bort alla mellanslag
                .replace(/,/g, ".");    // gör komma till punkt
        }

        function filterHats() {
            const searchValue = normalizeText(document.getElementById("hatSearch").value);
            const showSpecial = document.getElementById("showSpecialHats").checked;
            const rows = document.querySelectorAll("#hatTable tbody tr");

            rows.forEach(row => {
                const isStandard = row.dataset.standard === "true";
                const rowText = normalizeText(row.innerText);

                const matchesSearch = rowText.includes(searchValue);
                const matchesStandardFilter = showSpecial ? true : isStandard;

                row.style.display = (matchesSearch && matchesStandardFilter) ? "" : "none";
            });
        }

        document.getElementById("hatSearch").addEventListener("input", filterHats);
        document.getElementById("showSpecialHats").addEventListener("change", filterHats);

        document.addEventListener("DOMContentLoaded", function () {
            filterHats();
        });
    </script>
}