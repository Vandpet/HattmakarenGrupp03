@model HattmakarenWebbAppGrupp03.ViewModels.Messages.CreateConversationViewModel

@{
    ViewData["Title"] = "Ny konversation";
}

<h2>Ny konversation</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="SendToAll" class="form-check-input" />
        <label asp-for="SendToAll" class="form-check-label"></label>
    </div>

    <div class="mb-3">
        <label class="form-label">Välj mottagare</label>
        @foreach (var employee in Model.AvailableEmployees)
        {
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       name="SelectedEmployeeIds"
                       value="@employee.EmployeeId"
                       @(Model.SelectedEmployeeIds.Contains(employee.EmployeeId) ? "checked" : null) />
                <label class="form-check-label">@employee.FullName</label>
            </div>
        }
    </div>

    <div class="mb-3">
        <label asp-for="Content" class="form-label"></label>
        <textarea asp-for="Content" class="form-control" rows="6"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Skicka</button>
    <a asp-action="Index" class="btn btn-secondary">Avbryt</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}