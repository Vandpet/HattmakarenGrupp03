@model HattmakarenWebbAppGrupp03.ViewModels.Messages.ConversationThreadViewModel

@{
    ViewData["Title"] = "Conversation";
}

<div class="mb-3">
    <h2 class="mb-1">@Model.DisplayName</h2>
    <div class="text-muted small">
        Participants: @string.Join(", ", Model.Participants)
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card mb-4">
    <div class="card-body" style="min-height:200px;">
        @if (!Model.Messages.Any())
        {
            <p class="text-muted mb-0">No messages in the thread yet.</p>
        }
        else
        {
            @foreach (var message in Model.Messages)
            {
                <!-- Message bubbles: mine right-aligned, others left-aligned -->
                <div class="d-flex mb-3 @(message.IsMine ? "justify-content-end" : "justify-content-start")">
                    @if (!message.IsMine)
                    {
                        <div class="me-2 flex-shrink-0">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white"
                                 style="width:36px; height:36px; background:#AF75B2; font-weight:600;">
                                @((!string.IsNullOrWhiteSpace(message.SenderName) ? message.SenderName.Substring(0, 1).ToUpper() : "?"))
                            </div>
                        </div>
                    }

                    <div class="p-3 rounded" style="max-width:75ch; width:auto; @(message.IsMine ? "background:#E9D5EA; color:#333;" : "background:#ffffff; border:1px solid #e9e9e9;")">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <strong class="me-2" style="font-size:0.95rem;">@message.SenderName</strong>
                            <small class="text-muted" style="font-size:0.8rem;">@message.SentAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                        </div>
                        <div class="mt-1" style="white-space:pre-wrap;">@message.Content</div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Reply" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="conversationId" value="@Model.ConversationId" />

            <div class="mb-3">
                <label for="newMessageContent" class="form-label">Reply</label>
                <textarea name="newMessageContent" id="newMessageContent" class="form-control" rows="4" placeholder="Write a message..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-rosa">Send</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>