@model HattmakarenWebbAppGrupp03.Models.ViewModels.CustomActivityCreateViewModel

<link rel="stylesheet" href="~/css/CustomActivityCreate.css" asp-append-version="true" />


@{
    ViewData["Title"] = "Skapa arbetsuppgift";
    int? currentAccessLevel = Context.Session.GetInt32("AccessLevel");
    bool isAdmin = currentAccessLevel != null && currentAccessLevel >= 10;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header ljuslila">
                    <h3 class="mb-0">Create work assignment</h3>
                </div>

                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Name</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description / instructions</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Date" class="form-label">Date</label>
                            <input asp-for="Date" class="form-control" type="date" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Time" class="form-label">Tid</label>
                            <input asp-for="Time" type="time" class="form-control" />
                            <span asp-validation-for="Time" class="text-danger"></span>
                        </div>
                        @if (isAdmin)
                        {
                            <div class="mb-3">
                                <label asp-for="EId" class="form-label">Assigned to</label>
                                <select asp-for="EId" asp-items="Model.Employees" class="form-select">
                                    <option value="0">Choose employee</option>
                                </select>
                                <span asp-validation-for="EId" class="text-danger"></span>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" asp-for="EId" />
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn rosa fw-bold">Save</button>
                            <a asp-action="Index" class="btn rosa fw-bold">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}