@model IEnumerable<HattmakarenWebbAppGrupp03.Models.CustomActivity>

<link rel="stylesheet" href="~/css/CustomActivityIndex.css" asp-append-version="true" />


@{
    ViewData["Title"] = "Arbetsuppgifter";

    int? currentAccessLevel = Context.Session.GetInt32("AccessLevel");
    bool isAdmin = currentAccessLevel != null && currentAccessLevel >= 10;
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Arbetsuppgifter</h2>
        <a asp-action="Create" class="btn btn-success">Ny arbetsuppgift</a>
    </div>

    <div class="card shadow">
        <div class="card-body">

            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="ljuslila">
                    <tr>
                        <th>ID</th>
                        <th>Namn</th>
                        <th>Datum</th>
                        <th>Beskrivning</th>
                        <th>Anställd</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var activity in Model)
                    {
                        <tr onclick="window.location='@Url.Action("View", "CustomActivity", new { id = activity.AId })'"
                            style="cursor:pointer;">

                            <td>@activity.AId</td>

                            <td>@activity.Name</td>

                            <td>@activity.Date.ToString("yyyy-MM-dd")</td>

                            <td>
                                @{
                                    var desc = activity.Description ?? "";
                                    var shortDesc = desc.Length > 60
                                    ? desc.Substring(0, 60) + "..."
                                    : desc;
                                }
                                @shortDesc
                            </td>

                            <td>@activity.Employee?.Name</td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>