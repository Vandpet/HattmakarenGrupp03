@model HattmakarenWebbAppGrupp03.Models.CustomActivity

<link rel="stylesheet" href="~/css/CustomActivityView.css" asp-append-version="true" />


@{
    ViewData["Title"] = "Arbetsuppgift";

    int? currentAccessLevel = Context.Session.GetInt32("AccessLevel");
    bool isAdmin = currentAccessLevel != null && currentAccessLevel >= 10;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow">
                <div class="card-header ljuslila">
                    <h3 class="mb-0">Arbetsuppgift</h3>
                </div>

                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Namn</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Datum</dt>
                        <dd class="col-sm-8">@Model.Date.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-4">Tilldelad</dt>
                        <dd class="col-sm-8">@Model.Employee?.Name</dd>

                        <dt class="col-sm-4">Beskrivning</dt>
                        <dd class="col-sm-8">@Model.Description</dd>

                        @if (isAdmin)
                        {
                            <dt class="col-sm-4">Anställd-ID</dt>
                            <dd class="col-sm-8">@Model.EId</dd>
                        }
                    </dl>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn rosa fw-bold m-0">Tillbaka</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>