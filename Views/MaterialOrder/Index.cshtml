@model IEnumerable<HattmakarenWebbAppGrupp03.Models.MaterialOrder>

<h2>Materialbeställningar</h2>

<a asp-controller="MaterialOrder" asp-action="Create" class="btn btn-success mb-3">
    Ny materialbeställning +
</a>

<table class="table table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Status</th>
            <th>Hantera</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MoId</td>
                <td>
                    @if (item.Printed)
                    {
                        <span class="badge bg-success">Beställd</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ej beställd</span>
                    }
                </td>
                <td>
                    @if (!item.Printed)
                    {
                        <form asp-controller="MaterialOrder" asp-action="MarkAsSent" method="post">
                            <input type="hidden" name="id" value="@item.MoId" />
                            <button type="submit" class="btn btn-sm btn-outline-success">
                                Markera som beställd
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>