@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Order>

<h2>New material order</h2>

<a asp-controller="MaterialOrder" asp-action="Index" class="btn btn-secondary mb-3">
    Back
</a>

<form asp-controller="MaterialOrder" asp-action="Preview" method="post">
    @Html.AntiForgeryToken()

    <table class="table table-hover">
        <thead>
            <tr>
                <th>Choose</th>
                <th>Order nr</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Delivery</th>
                <th>Amount hats</th>
                <th>Status</th>
                <th>Downloaded</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>
                        <input type="checkbox" name="selectedOrderIds" value="@order.OId" />
                    </td>
                    <td>@order.OId</td>
                    <td>@order.Customer?.Name</td>
                    <td>@order.OrderDate.ToShortDateString()</td>
                    <td>@order.PrelDeliveryDate.ToShortDateString()</td>
                    <td>@(order.HatOrders?.Sum(h => h.Amount) ?? 0)</td>
                    <td>@order.Status</td>
                    <td>@order.Downloaded</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex gap-2">
        @* <button type="submit" class="btn btn-success">
            Sammanställ material
        </button> *@
        <button type="submit"
                formaction="@Url.Action("DownloadCombinedMaterialsPdf", "MaterialOrder")"
                class="btn btn-primary">
            Download combined material list
        </button>
    </div>

</form>
