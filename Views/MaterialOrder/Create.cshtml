@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Order>

<h2>Ny materialbeställning</h2>

<a asp-controller="MaterialOrder" asp-action="Index" class="btn btn-secondary mb-3">
    Tillbaka
</a>

<form asp-controller="MaterialOrder" asp-action="Preview" method="post">
    @Html.AntiForgeryToken()

    <table class="table table-hover">
        <thead>
            <tr>
                <th>Välj</th>
                <th>Ordernr</th>
                <th>Kund</th>
                <th>Datum</th>
                <th>Leverans</th>
                <th>Antal hattar</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>
                        <input type="checkbox" name="selectedOrderIds" value="@order.OId" />
                    </td>
                    <td>@order.OId</td>
                    <td>@order.Customer?.Name</td>
                    <td>@order.OrderDate.ToShortDateString()</td>
                    <td>@order.PrelDeliveryDate.ToShortDateString()</td>
                    <td>@(order.HatOrders?.Sum(h => h.Amount) ?? 0)</td>
                    <td>@order.Status</td>
                </tr>
            }
        </tbody>
    </table>

  
</form>