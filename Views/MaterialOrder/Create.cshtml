@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Order>

<h2>New Material Order</h2>

<a asp-controller="MaterialOrder" asp-action="Index" class="btn rosa fw-bold mb-3">
    Back
</a>

<form asp-controller="MaterialOrder" asp-action="Preview" method="post">
    @Html.AntiForgeryToken()

    <table class="table table-hover">
        <thead>
            <tr>
                <th>Select</th>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Delivery Date</th>
                <th>Amount of Hats</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>
                        <input type="checkbox" name="selectedOrderIds" value="@order.OId" />
                    </td>
                    <td>@order.OId</td>
                    <td>@order.Customer?.Name</td>
                    <td>@order.OrderDate.ToShortDateString()</td>
                    <td>@order.PrelDeliveryDate.ToShortDateString()</td>
                    <td>@(order.HatOrders?.Sum(h => h.Amount) ?? 0)</td>
                    <td>@order.Status</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex gap-2">
        <button type="submit" class="btn rosa fw-bold">
            Summarize material
        </button>
        <button type="submit"
                formaction="@Url.Action("DownloadCombinedMaterialsPdf", "MaterialOrder")"
                class="btn rosa fw-bold">
            Download PDF
        </button>
    </div>

    @* <button type="submit" class="btn rosa fw-bold">
        Summarize material
    </button> *@
</form>
