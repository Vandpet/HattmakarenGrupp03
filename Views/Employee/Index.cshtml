@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Employee>

@{
    ViewData["Title"] = "Användare";
    int? currentAccessLevel = Context.Session.GetInt32("AccessLevel");
    int? currentEmployeeId = Context.Session.GetInt32("EmployeeId");
    bool isAdmin = currentAccessLevel != null && currentAccessLevel >= 10;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Användare</h2>
        <div class="d-flex gap-2">
            @if (isAdmin)
            {
                <a asp-controller="Employee" asp-action="Create" class="btn btn-success">Ny användare</a>
            }
            <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger">Logga ut</a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Namn</th>
                        <th>Adress</th>
                        <th>Telefon</th>
                        <th>Användarnamn</th>
                        <th>Accessnivå</th>
                        @if (isAdmin)
                        {
                            <th style="width: 180px;">Åtgärder</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var employee in Model)
                    {
                        <tr>
                            <td>@employee.EId</td>
                            <td>@employee.Name</td>
                            <td>@employee.Adress</td>
                            <td>@employee.PhoneNr</td>
                            <td>@employee.Username</td>
                            <td>@employee.accesslevel</td>

                            @if (isAdmin)
                            {
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@employee.EId" class="btn btn-sm btn-primary">
                                            Redigera
                                        </a>

                                        @if (currentEmployeeId != employee.EId)
                                        {
                                            <a asp-action="Delete" asp-route-id="@employee.EId" class="btn btn-sm btn-danger">
                                                Ta bort
                                            </a>
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>