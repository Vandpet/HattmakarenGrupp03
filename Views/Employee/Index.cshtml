@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Employee>

<link rel="stylesheet" href="~/css/EmployeeIndexMobile.css" asp-append-version="true" />


@{
	ViewData["Title"] = "Användare";
	int? currentAccessLevel = Context.Session.GetInt32("AccessLevel");
	int? currentEmployeeId = Context.Session.GetInt32("EmployeeId");
	bool isAdmin = currentAccessLevel != null && currentAccessLevel >= 10;
}

<div class="container mt-5">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="mb-0">User</h2>
		<div class="d-flex gap-2">
			@if (isAdmin)
			{
				<a asp-controller="Employee" asp-action="Create" class="btn btn-success">New User</a>
			}
			<a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger">Logout</a>
		</div>
	</div>

	<div class="card shadow">
		<div class="card-body">
			<table class="table table-striped table-hover align-middle mb-0">
				<thead class="ljuslila">
					<tr>
						<th>ID</th>
						<th>Name</th>
						<th>Address</th>
						<th>Phone Number</th>
						<th>Email</th>
						<th>Username</th>
						@if (isAdmin)
						{
							<th>Access Level</th>
						}
						<th style="width: 180px;">Actions</th>

					</tr>
				</thead>
				<tbody>
					@foreach (var employee in Model)
					{
						bool isCurrentUser = currentEmployeeId == employee.EId;
						<tr>
							<td>@employee.EId</td>
							<td>@employee.Name</td>
							<td>@employee.Adress</td>
							<td>@employee.PhoneNr</td>
							<td><a href="mailto:@employee.Email">@employee.Email</a></td>
							<td>@employee.Username</td>
							@if (isAdmin)
							{
								<td>@employee.accesslevel</td>

							}
							<td>
								@if (isAdmin || isCurrentUser)
								{
									<a asp-action="Edit" asp-route-id="@employee.EId" class="btn btn-sm btn-outline-primary">Edit</a>
								}

								@if (isAdmin)
								{
									<a asp-action="Delete" asp-route-id="@employee.EId" class="btn btn-sm btn-outline-danger">Delete</a>
								}
							</td>
						</tr>

					}
				</tbody>
			</table>
		</div>
	</div>
</div>