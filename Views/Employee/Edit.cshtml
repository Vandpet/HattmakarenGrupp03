@model HattmakarenWebbAppGrupp03.Models.ViewModels.EmployeeEditViewModel

<link rel="stylesheet" href="~/css/EmployeeEditMobile.css" asp-append-version="true" />


@{
    ViewData["Title"] = "Redigera användare";
    int? currentAccessLevel = Context.Session.GetInt32("AccessLevel");
    bool isAdmin = currentAccessLevel != null && currentAccessLevel >= 10;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header ljuslila">
                    <h3 class="mb-0">Edit user</h3>
                </div>

                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="EId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Name</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Adress" class="form-label">Address</label>
                            <input asp-for="Adress" class="form-control" />
                            <span asp-validation-for="Adress" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNr" class="form-label">Phone Number</label>
                            <input asp-for="PhoneNr" class="form-control" />
                            <span asp-validation-for="PhoneNr" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        @if (isAdmin)
                        {
                            <div class="mb-3">
                                <label asp-for="accesslevel" class="form-label">Role</label>
                                <select asp-for="accesslevel" class="form-control">
                                <option value="1">User</option>
                                <option value="10">Admin</option>
                                </select>
                                <span asp-validation-for="accesslevel" class="text-danger"></span>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label">Username</label>
                            <input asp-for="Username" class="form-control" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label">New Password</label>

                            <div class="input-group">
                                <input asp-for="NewPassword" type="password" class="form-control" id="newPasswordInput" />
                                <button type="button" class="btn btn-secondary" id="generateNewPasswordBtn">Generate</button>
                                <button type="button" class="btn btn-outline-secondary" id="toggleNewPasswordBtn">Show</button>
                            </div>

                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                            <div class="form-text">Leave empty if the password should not be changed.</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn rosa fw-bold">Save changes</button>
                            <a asp-action="Index" class="btn rosa fw-bold">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById("generateNewPasswordBtn").addEventListener("click", function () {
            const password = generatePassword(12);
            const input = document.getElementById("newPasswordInput");

            input.value = password;
            input.type = "text";

            document.getElementById("toggleNewPasswordBtn").textContent = "Hide";
        });

        document.getElementById("toggleNewPasswordBtn").addEventListener("click", function () {
            const input = document.getElementById("newPasswordInput");

            if (input.type === "password") {
                input.type = "text";
                this.textContent = "Hide";
            } else {
                input.type = "password";
                this.textContent = "Show";
            }
        });

        function generatePassword(length) {
            const uppercase = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
            const lowercase = "abcdefghijklmnopqrstuvwxyz";
            const numbers = "0123456789";
            const special = "!#$%&*?-_";
            const all = uppercase + lowercase + numbers + special;

            let password = "";

            password += getRandomChar(uppercase);
            password += getRandomChar(special);

            while (password.length < length) {
                password += getRandomChar(all);
            }

            return shuffleString(password);
        }

        function getRandomChar(chars) {
            return chars[Math.floor(Math.random() * chars.length)];
        }

        function shuffleString(str) {
            return str
                .split("")
                .sort(() => Math.random() - 0.5)
                .join("");
        }
    </script>
}