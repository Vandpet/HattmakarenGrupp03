@model HattmakarenWebbAppGrupp03.Models.ViewModels.EmployeeCreateViewModel

@{
    ViewData["Title"] = "Skapa första användaren";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <h3 class="mb-0">Skapa första användaren</h3>
                </div>

                <div class="card-body">
                    <p class="text-muted">
                        Ingen användare finns i databasen ännu. Skapa första användaren här.
                    </p>

                    <form asp-action="SetupFirstUser" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Namn</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Adress" class="form-label">Adress</label>
                            <input asp-for="Adress" class="form-control" />
                            <span asp-validation-for="Adress" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNr" class="form-label">Telefonnummer</label>
                            <input asp-for="PhoneNr" class="form-control" />
                            <span asp-validation-for="PhoneNr" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="accesslevel" class="form-label">Accessnivå</label>
                            <input asp-for="accesslevel" class="form-control" value="10" />
                            <span asp-validation-for="accesslevel" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label">Användarnamn</label>
                            <input asp-for="Username" class="form-control" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label">Lösenord</label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Skapa första användaren</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}