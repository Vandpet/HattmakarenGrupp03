@model HattmakarenWebbAppGrupp03.Models.Employee

@{
    ViewData["Title"] = "Ta bort användare";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">Ta bort användare</h3>
                </div>

                <div class="card-body">
                    <p class="mb-4">
                        Are you sure you want to remove this user?
                    </p>

                    <div class="alert alert-warning">
                        The user will not be permanently removed from the database, but will only be hidden from the system.
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.EId</dd>

                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Address</dt>
                        <dd class="col-sm-8">@Model.Adress</dd>

                        <dt class="col-sm-4">Phone Number</dt>
                        <dd class="col-sm-8">@Model.PhoneNr</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Username</dt>
                        <dd class="col-sm-8">@Model.Username</dd>

                        <dt class="col-sm-4">Access Level</dt>
                        <dd class="col-sm-8">@Model.accesslevel</dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@Model.EId" />
                        <button type="submit" class="btn btn-danger">Yes, delete</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>