@model HattmakarenWebbAppGrupp03.Models.Customer

@{
    ViewData["Title"] = "Kundprofil";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Customer profile</h3>
                </div>

                <div class="card-body">

                    <dl class="row">

                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Address</dt>
                        <dd class="col-sm-8">@Model.Adress</dd>

                        <dt class="col-sm-4">Phone Number</dt>
                        <dd class="col-sm-8">@Model.PhoneNr</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.Email))
                            {
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            }
                        </dd>

                        <dt class="col-sm-4">Country</dt>
                        <dd class="col-sm-8">@Model.Country</dd>

                        <dt class="col-sm-4">City</dt>
                        <dd class="col-sm-8">@Model.City</dd>

                        <dt class="col-sm-4">Language</dt>
                        <dd class="col-sm-8">@Model.Language</dd>

                    </dl>
                    <div class="mt-3">
                        <a asp-action="Index" class="btn btn-secondary">Back</a>
                        <a asp-action="Edit" asp-route-id="@Model.CId" class="btn btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@Model.CId" class="btn btn-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
