@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Customer>

<link rel="stylesheet" href="~/css/CustomerIndexMobile.css" asp-append-version="true" />


@{
	ViewData["Title"] = "Kunder";
	int? currentEmployeeId = Context.Session.GetInt32("EmployeeId");
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Customers</h2>
        <div class="d-flex gap-2">
                <a asp-controller="Customer" asp-action="Create" class="btn btn-success">New customer</a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="ljuslila">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Address</th>
                        <th>Phone number</th>
                        <th>Email</th>
                        <th>Country</th>
                        <th>City</th>
                        <th>Language</th>
                        <th style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var customer in Model)
                    {
                        <tr>
                            <td>@customer.CId</td>
                            <td>@customer.Name</td>
                            <td>@customer.Adress</td>
                            <td>@customer.PhoneNr</td>
                            <td><a href="mailto:@customer.Email">@customer.Email</a></td>
                            <td>@customer.Country</td>
                            <td>@customer.City</td>
                            <td>@customer.Language</td>
                            <td>
                               <div class="d-flex align-items-center gap-2">
                                <a asp-action="View" asp-route-id="@customer.CId" class="btn btn-sm btn-outline-info">Show</a>
                                <a asp-action="Edit" asp-route-id="@customer.CId" class="btn btn-sm btn-outline-info">Edit</a>
                                <a asp-action="Delete" asp-route-id="@customer.CId" class="btn btn-sm btn-outline-danger text-nowrap">Remove</a>
                               </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div> 