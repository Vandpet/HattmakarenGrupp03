@model HattmakarenWebbAppGrupp03.Models.ViewModels.ShippingLabelViewModel
@{
    Layout = "_Layout";
}
    <h2>Fraktsedel – Order #@Model.OId</h2>

    <form asp-action="DownloadShippingLabel" method="post">
        <input type="hidden" asp-for="OId" />
        <input type="hidden" asp-for="CustomerId" />
        <input type="hidden" asp-for="CustomerName" />
        <input type="hidden" asp-for="CustomerAddress" />
    <input type="hidden" asp-for="CustomerCity" />
        <input type="hidden" asp-for="CustomerCountry" />
        <input type="hidden" asp-for="DateCreated" />

        <h5>Hattmakaren AB</h5>
        <input asp-for="CompanyAddress" class="form-control" placeholder="Företagets adress" />
        <input asp-for="CompanyPostalCode" class="form-control" placeholder="Postnummer" />
        <input asp-for="CompanyCity" class="form-control" placeholder="Stad" />
        <input asp-for="CompanyCountry" class="form-control" placeholder="LAND" />

        <hr />

        <input asp-for="Contents" class="form-control" placeholder="Innehåll" />
        <br />
        <p>Weight of package i kilo</p>
        <input asp-for="Weight" class="form-control" placeholder="Vikt (kg)" type="number" step="0.1" />
        <br />
        <p>Delivery price</p>
        <input asp-for="DeliveryPrice" class="form-control" placeholder="Fraktpris (kr)" type="number" step="0.01" />

        <div class="form-check mt-2">
            <input asp-for="ShipOutsideCountry" class="form-check-input" type="checkbox" />
        <p>Is the package being sent outside of the country?</p>
            <label class="form-check-label">Yes</label>
        </div> 
    

        <button type="submit" class="btn rosa fw-bold mt-3">Skapa fraktsedel PDF</button>
    </form>
