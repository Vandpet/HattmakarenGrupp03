@model HattmakarenWebbAppGrupp03.Models.ViewModels.ShippingLabelViewModel
@{
    Layout = "_Layout";
}
    <h2>Shipping Label – Order #@Model.OId</h2>

    <form asp-action="DownloadShippingLabel" method="post">
        <input type="hidden" asp-for="OId" />
        <input type="hidden" asp-for="CustomerId" />
        <input type="hidden" asp-for="CustomerName" />
        <input type="hidden" asp-for="CustomerAddress" />
    <input type="hidden" asp-for="CustomerCity" />
        <input type="hidden" asp-for="CustomerCountry" />
        <input type="hidden" asp-for="DateCreated" />

        <h5>Hattmakaren AB</h5>
        <input asp-for="CompanyAddress" class="form-control" placeholder="Company Address" />
        <input asp-for="CompanyPostalCode" class="form-control" placeholder="Postal Code" />
        <input asp-for="CompanyCity" class="form-control" placeholder="City" />
        <input asp-for="CompanyCountry" class="form-control" placeholder="Country" />

        <hr />

        <input asp-for="Contents" class="form-control" placeholder="Contents" />
        <br />
        <p>Weight of package in kilograms</p>
        <input asp-for="Weight" class="form-control" placeholder="Weight (kg)" type="number" step="0.1" />
        <br />
        <p>Delivery price</p>
        <input asp-for="DeliveryPrice" class="form-control" placeholder="Delivery Price (SEK)" type="number" step="0.01" />

        <div class="form-check mt-2">
            <input asp-for="ShipOutsideCountry" class="form-check-input" type="checkbox" />
        <p>Is the package being sent outside of the country?</p>
            <label class="form-check-label">Yes</label>
        </div> 
    

        <button type="submit" class="btn rosa fw-bold mt-3">Create Shipping Label PDF</button>
    </form>
