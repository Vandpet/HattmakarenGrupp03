@model HattmakarenWebbAppGrupp03.Models.ViewModels.CreateOrderViewModel

<link rel="stylesheet" href="~/css/OrderCreateMobile.css" asp-append-version="true" />
@* Lade också till <dv class="table-responsive"></dv> på både standardhattabellen och specialhattabellen
 *@

<h2>Skapa ny order (Lagerförda modeller)</h2>

<form asp-action="Create" method="post">
	<div class="form-group">
		<label>Välj Kund</label>
		<select asp-for="SelectedCustomerId" asp-items="Model.CustomerList" class="form-control">
			<option value="">-- Välj kund --</option>
		</select>
		<span asp-validation-for="SelectedCustomerId" class="text-danger"></span>
	</div>

	<hr />
	<h4>Välj Hattar</h4>

	<div class="text-danger mb-2">
		<div asp-validation-summary="ModelOnly"></div>
	</div>

	<div class="table-responsive">
	<table class="table">
		<thead>
			<tr>
				<th>Välj</th>
				<th>Namn</th>
				<th>Storlek</th>
				<th>Pris</th>
			</tr>
		</thead>
		<tbody>
			@for (int i = 0; i < Model.StandardHats.Count; i++)
			{
				var hat = Model.StandardHats[i];

				<tr>
					<td>
						<input type="hidden" name="HatRows.HId[@i]" value="@hat.HId" />
						<input type="number" name="HatRows.Amount[@i]" value="0" min="0" style="max-width: 60px;" />
					</td>

					<td>@hat.Name</td>
					<td>@hat.Size</td>
					<td>@hat.Price.ToString("C")</td>
				</tr>
			}
		</tbody>
	</table>
	</div>

	<h4>Specialbeställda hattar</h4>
	<div class="table-responsive">
	<table class="table" id="customHatsTable">
		<thead>
			<tr>
				<th>Välj</th>
				<th>Namn</th>
				<th>Beskrivning</th>
				<th>Pris</th>
			</tr>
		</thead>
		<tbody>
		</tbody>
	</table>
	</div>


	<div>
		<button type="button" class="btn rosa fw-bold m-0" id="openCustomHatModalBtn">
			Skapa Specialbeställd Hatt
		</button>
	</div>


	<div class="form-group mt-3">
		<label asp-for="PrelDeliveryDate">Preliminärt leveransdatum</label>
		<input asp-for="PrelDeliveryDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
		<span asp-validation-for="PrelDeliveryDate" class="text-danger"></span>
	</div>

	<div class="form-group mt-3">
		<label asp-for="Description">Beskrivning/Notering</label>
		<textarea asp-for="Description" class="form-control"></textarea>
	</div>

	<div class="d-flex gap-3 align-items-end">
		<div class="form-group mt-3">
			<label asp-for="Discount">Rabatt (%)</label>
			<input asp-for="Discount" type="number" min="0" max="100" class="form-control" style="max-width: 60px" />
			<span asp-validation-for="Discount" class="text-danger"></span>
		</div>

		<div class="form-group flex-grow-1">
			<label asp-for="DiscountDesc">Rabattbeskrivning (max 50 tecken)</label>
			<input asp-for="DiscountDesc" maxlength="50" class="form-control" />
			<span asp-validation-for="DiscountDesc" class="text-danger"></span>
		</div>
	</div>

	<div class="form-group mt-3">
		<label asp-for="DeliveryFee">Delivery Fee (SEK)</label>
		<input asp-for="DeliveryFee" type="number" min="0" class="form-control" />
		<span asp-validation-for="DeliveryFee" class="text-danger"></span>
	</div>

	<div class="form-check mt-3">
		<input asp-for="IsExpress" class="form-check-input" />
		<label asp-for="IsExpress" class="form-check-label">Expressbeställning (+20%)</label>
	</div>

	<button type="submit" class="btn rosa fw-bold m-0 mt-3">Skapa Order</button>
</form>

<div class="modal fade" id="customHatModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-lg modal-dialog-scrollable">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Skapa specialbeställd hatt</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Stäng"></button>
			</div>
			<div class="modal-body" id="customHatModalBody">
				<div>Laddar formulär...</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />

	<script>
		let customHatIndex = @Model.StandardHats.Count;

		const modalElement = document.getElementById('customHatModal');
		const modalBody = document.getElementById('customHatModalBody');
		const openModalBtn = document.getElementById('openCustomHatModalBtn');
		const customHatModal = new bootstrap.Modal(modalElement);

		openModalBtn.addEventListener('click', async function () {
			const response = await fetch('/Hat/CreateModal');
			const html = await response.text();

			modalBody.innerHTML = html;
			customHatModal.show();
		});

		modalBody.addEventListener('click', async function (e) {
			if (e.target && e.target.id === 'addMaterialBtn') {
				addMaterial();
			}

			if (e.target && e.target.classList.contains('remove-btn')) {
				e.target.closest('.material-item').remove();
				reindexMaterials();
			}

			if (e.target && e.target.id === 'saveCustomHatBtn') {
				e.preventDefault();

				const form = document.getElementById('createCustomHatForm');
				if (!form) return;

				const formData = new FormData(form);

				const response = await fetch('/Hat/CreateModal', {
					method: 'POST',
					body: formData
				});

				const contentType = response.headers.get("content-type") || "";

				if (contentType.includes("application/json")) {
					const result = await response.json();

					if (result.success) {
						addCustomHatToOrder(result);
						customHatModal.hide();
					}
				} else {
					const html = await response.text();
					modalBody.innerHTML = html;
				}
			}
		});

		function addMaterial() {
			const container = document.getElementById("materials-container");
			const index = container.querySelectorAll(".material-item").length;

			const template = document.querySelector("#material-template .material-item");
			const clone = template.cloneNode(true);

			clone.querySelector(".name").setAttribute("name", `Materials[${index}].Name`);
			clone.querySelector(".amount").setAttribute("name", `Materials[${index}].Amount`);
			clone.querySelector(".unit").setAttribute("name", `Materials[${index}].MeasuringUnits`);
			clone.querySelector(".price").setAttribute("name", `Materials[${index}].Price`);

			container.appendChild(clone);
		}

		function reindexMaterials() {
			const items = document.querySelectorAll("#materials-container .material-item");

			items.forEach((item, index) => {
				item.querySelectorAll("input").forEach(input => {
					if (input.name.includes("Name"))
						input.name = `Materials[${index}].Name`;
					else if (input.name.includes("Amount"))
						input.name = `Materials[${index}].Amount`;
					else if (input.name.includes("MeasuringUnits"))
						input.name = `Materials[${index}].MeasuringUnits`;
					else if (input.name.includes("Price"))
						input.name = `Materials[${index}].Price`;
				});
			});
		}

		function addCustomHatToOrder(hat) {
			const tbody = document.querySelector("#customHatsTable tbody");

			const row = document.createElement("tr");
			row.innerHTML = `
				<td>
					<input type="hidden" name="HatRows.HId[${customHatIndex}]" value="${hat.hId}" />
					<input type="number" name="HatRows.Amount[${customHatIndex}]" value="1" min="1" class="form-control" style="max-width: 60px;" />
				</td>
				<td>${hat.name}</td>
				<td class="text-truncate" style="max-width: 85px;">${hat.description}</td>
				<td>${hat.price} kr</td>
			`;

			tbody.appendChild(row);
			customHatIndex++;
		}
	</script>
}