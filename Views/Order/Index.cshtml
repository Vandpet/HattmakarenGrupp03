@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Order>


<link rel="stylesheet" href="~/css/OrderIndexMobile.css" asp-append-version="true" />
@{
	var selected = ViewBag.Filter as string;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Order Overview</h2>
    <a asp-action="Create" class="btn btn-success">New Order +</a>
</div>

<div>
    <form method="get" asp-controller="Order" asp-action="Index">
        <label class="btn text-start @(selected == "nyligen" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="nyligen" onchange="this.form.submit()" class="d-none" />
            Recently Added
        </label>
        <label class="btn text-start @(selected == "ej-påbörjade" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="ej-påbörjade" onchange="this.form.submit()" class="d-none" />
            Not Started
        </label>
        <label class="btn text-start @(selected == "påbörjade" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="påbörjade" onchange="this.form.submit()" class="d-none" />
            Started
        </label>
        <label class="btn text-start @(selected == "färdig" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="färdig" onchange="this.form.submit()" class="d-none" />
            Completed
        </label>
        <label class="btn text-start @(selected == "avslutade" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="avslutade" onchange="this.form.submit()" class="d-none" />
            Shipped
        </label>
        <label class="btn text-start @(selected == "returnerad" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="returnerad" onchange="this.form.submit()" class="d-none" />
            Returned
        </label>
        <label class="btn text-start @(selected == "alla-ordrar" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="alla-ordrar" onchange="this.form.submit()" class="d-none" />
            All
        </label>
    </form>

</div>

<div class="table-responsive">
<table class="table table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Order nr</th>
            <th>Date</th>
            <th>Estimated Delivery</th>
            <th>Customer</th>
            <th>Created By</th>
            <th>Quantity</th>
            <th>Status</th>
            <th>Price (incl. VAT)</th>
            <th>Express</th>
            <th>Manage</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.OId</td>
                <td>@item.OrderDate.ToShortDateString()</td>
                <td>@item.PrelDeliveryDate.ToShortDateString()</td>
                <td>@item.Customer?.Name</td>
                <td>@item.CreatedBy?.Name</td>
                <td>@(item.HatOrders?.Sum(h => h.Amount) ?? 0)</td>
                <td>
                    <span class="badge @(ColorForBadge(item.Status))">
                        @item.Status
                    </span>
                </td>
                <td>@item.Price.ToString("C")</td>
                <td>
                    @if (item.Express)
                    {
                        <span class="text-danger" title="Prioriteras!">⚡ Yes</span>
                    }
                    else
                    {
                        <span>No</span>
                    }
                </td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-oId="@item.OId" class="btn btn-sm btn-outline-info">View</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No orders found in the system.</div>
}

@functions {
    public string ColorForBadge(string itemStatus)
    {
        if (itemStatus == "Ej Påbörjad")
        {
            return "bg-secondary";
        }
        else if (itemStatus == "Påbörjad")
        {
            return "bg-primary";
        }
        else if (itemStatus == "Färdig")
        {
            return "bg-success";
        }
        else // if (itemStatus == "Skickad")
        {
            return "bg-rosa text-dark";

        }



    }
}



}



