@model IEnumerable<HattmakarenWebbAppGrupp03.Models.Order>
@{
	var selected = ViewBag.Filter as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Orderöversikt</h2>
    <a asp-action="Create" class="btn btn-success">Ny Beställning +</a>
</div>



<div>
    <form method="get" asp-controller="Order" asp-action="Index">
        <label class="btn text-start @(selected == "alla-ordrar" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="alla-ordrar" onchange="this.form.submit()" class="d-none" />
            Alla Ordrar
        </label>
        <label class="btn text-start @(selected == "nyligen" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="nyligen" onchange="this.form.submit()" class="d-none" />
            Nyligen Tillagda
        </label>
        <label class="btn text-start @(selected == "påbörjade" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="påbörjade" onchange="this.form.submit()" class="d-none" />
            Påbörjade Ordrar
        </label>
        <label class="btn text-start @(selected == "avslutade" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="avslutade" onchange="this.form.submit()" class="d-none" />
            Avslutade Ordrar
        </label>
        <label class="btn text-start @(selected == "ej-påbörjade" ? "btn-ljuslila" : "btn-rosa")">
            <input type="radio" name="filter" value="ej-påbörjade" onchange="this.form.submit()" class="d-none" />
            Ej Påbörjade Ordrar
        </label>
    </form>

</div>

<table class="table table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Ordernr</th>
            <th>Datum</th>
            <th>Beräknad leverans</th>
            <th>Kund</th>
            <th>Skapad av</th>
            <th>Antal</th>
            <th>Status</th>
            <th>Pris</th>
            <th>Express</th>
            <th>Hantera</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.OId</td>
                <td>@item.OrderDate.ToShortDateString()</td>
                <td>@item.PrelDeliveryDate.ToShortDateString()</td>
                <td>@item.Customer?.Name</td>
                <td>@item.CreatedBy?.Name</td>
                <td>@(item.HatOrders?.Sum(h => h.Amount) ?? 0)</td>
                <td>
                    <span class="badge @(ColorForBadge(item.Status))">
                        @item.Status
                    </span>
                </td>
                <td>@item.Price.ToString("C")</td>
                <td>
                    @if (item.Express)
                    {
                        <span class="text-danger" title="Prioriteras!">⚡ Ja</span>
                    }
                    else
                    {
                        <span>Nej</span>
                    }
                </td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-oId="@item.OId" class="btn btn-sm btn-outline-info">Visa</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">Inga ordrar hittades i systemet.</div>
}

@functions {
    public string ColorForBadge(string itemStatus)
    {
        if (itemStatus == "Ej Påbörjad")
        {
            return "bg-secondary";
        }
        else if (itemStatus == "Påbörjad")
        {
            return "bg-primary";
        }
        else if (itemStatus == "Färdig")
        {
            return "bg-success";
        }
        else // if (itemStatus == "Skickad")
        {
            return "bg-skickad text-dark";

        }
    }
}